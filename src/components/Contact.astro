---
import { site } from "../data/site";
const year = new Date().getFullYear();
---

<section
  id="contact"
  class="anchor-offset relative overflow-hidden py-20 md:py-44"
>
  <!-- Parallax depth -->
  <div class="pointer-events-none absolute inset-0 -z-10">
    <div
      data-parallax="0.2"
      class="absolute left-1/2 top-1/3 h-[40vw] max-h-[520px] w-[40vw] max-w-[520px] -translate-x-1/2 rounded-full opacity-40 blur-[90px]"
      style="background: radial-gradient(circle at center, #673ab7, transparent 68%);"
    >
    </div>
  </div>

  <div class="shell">
    <p class="eyebrow mb-8" data-reveal>(04) — Contact</p>

    <h2
      class="max-w-4xl text-4xl font-semibold leading-[1.05] tracking-tightest md:text-7xl"
    >
      <span class="block overflow-hidden" data-mask>
        <span class="block">Let&rsquo;s build</span>
      </span>
      <span class="block overflow-hidden" data-mask>
        <span class="block"
          >something <span class="text-accent">great</span>.</span
        >
      </span>
    </h2>

    <div class="mt-12 flex flex-col gap-10 md:flex-row md:items-end md:justify-between">
      <div data-reveal>
        <p class="eyebrow mb-3">Email</p>
        <a
          href={`mailto:${site.email}`}
          class="link-underline text-xl font-medium md:text-2xl"
        >
          {site.email}
        </a>
      </div>

      <div class="flex flex-wrap gap-3" data-reveal>
        <a
          href={site.social.github}
          target="_blank"
          rel="noopener noreferrer"
          class="rounded-full border border-foreground/20 px-5 py-2.5 text-sm transition-colors duration-300 hover:border-secondary hover:bg-secondary hover:text-foreground"
        >
          GitHub
        </a>
        <a
          href={site.social.linkedin}
          target="_blank"
          rel="noopener noreferrer"
          class="rounded-full border border-foreground/20 px-5 py-2.5 text-sm transition-colors duration-300 hover:border-secondary hover:bg-secondary hover:text-foreground"
        >
          LinkedIn
        </a>
      </div>
    </div>
  </div>

  <footer
    class="shell mt-24 flex flex-col gap-2 border-t border-foreground/10 pt-8 text-sm text-foreground-faint md:flex-row md:items-center md:justify-between"
  >
    <p>© {year} {site.name}</p>
    <p>{site.role} · {site.location}</p>
    <p>Built with Astro · Vue · GSAP</p>
  </footer>
</section>

<script>
  import { gsap, ScrollTrigger } from "../lib/gsap";

  function revealContact() {
    const el = document.getElementById("contact");
    if (!el) return;
    const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    const masks = el.querySelectorAll<HTMLElement>("[data-mask] > *");
    const reveals = el.querySelectorAll<HTMLElement>("[data-reveal]");

    if (reduce) {
      gsap.set(masks, { yPercent: 0 });
      gsap.set(reveals, { autoAlpha: 1, y: 0 });
      return;
    }

    gsap.fromTo(
      masks,
      { yPercent: 110 },
      {
        yPercent: 0,
        duration: 1,
        ease: "power4.out",
        stagger: 0.1,
        scrollTrigger: { id: "reveal", trigger: el, start: "top 75%" },
      },
    );
    gsap.fromTo(
      reveals,
      { autoAlpha: 0, y: 40 },
      {
        autoAlpha: 1,
        y: 0,
        duration: 0.9,
        ease: "power3.out",
        stagger: 0.1,
        scrollTrigger: { id: "reveal", trigger: el, start: "top 70%" },
      },
    );
    ScrollTrigger.refresh();
  }

  document.addEventListener("astro:page-load", revealContact);
</script>
