---
import { site } from "../data/site";
const year = new Date().getFullYear();
---

<section
  id="contact"
  class="anchor-offset relative overflow-hidden py-20 md:py-40"
>
  <!-- Parallax depth -->
  <div class="pointer-events-none absolute inset-0 -z-10">
    <div
      data-parallax="0.2"
      class="absolute left-1/2 top-1/3 h-[40vw] max-h-[520px] w-[40vw] max-w-[520px] -translate-x-1/2 rounded-full opacity-40 blur-[90px]"
      style="background: radial-gradient(circle at center, #a81f45, transparent 68%);"
    >
    </div>
  </div>

  <div class="shell">
    <p class="eyebrow mb-8" data-reveal>(04) — Contact</p>

    <h2
      class="max-w-4xl text-4xl font-semibold leading-[1.05] tracking-tightest md:text-7xl"
    >
      <span class="block overflow-hidden" data-mask>
        <span class="block">Let&rsquo;s build</span>
      </span>
      <span class="block overflow-hidden" data-mask>
        <span class="block"
          >something <span class="text-accent">great</span>.</span
        >
      </span>
    </h2>

    <div class="mt-12 flex justify-center">
      <div class="flex flex-wrap justify-center gap-3" data-reveal>
        <a
          href={`mailto:${site.email}`}
          aria-label="Email"
          class="inline-flex h-12 w-12 items-center justify-center rounded-full border border-foreground/20 transition-colors duration-300 hover:border-secondary hover:bg-secondary hover:text-foreground"
        >
          <svg viewBox="0 0 24 24" aria-hidden="true" class="h-5 w-5" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round">
            <rect x="2" y="4" width="20" height="16" rx="2"></rect>
            <path d="m2 6 10 7L22 6"></path>
          </svg>
        </a>
        <a
          href={site.social.github}
          target="_blank"
          rel="noopener noreferrer"
          aria-label="GitHub"
          class="inline-flex h-12 w-12 items-center justify-center rounded-full border border-foreground/20 transition-colors duration-300 hover:border-secondary hover:bg-secondary hover:text-foreground"
        >
          <svg viewBox="0 0 24 24" aria-hidden="true" class="h-5 w-5" fill="currentColor">
            <path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"></path>
          </svg>
        </a>
        <a
          href={site.social.linkedin}
          target="_blank"
          rel="noopener noreferrer"
          aria-label="LinkedIn"
          class="inline-flex h-12 w-12 items-center justify-center rounded-full border border-foreground/20 transition-colors duration-300 hover:border-secondary hover:bg-secondary hover:text-foreground"
        >
          <svg viewBox="0 0 24 24" aria-hidden="true" class="h-5 w-5" fill="currentColor">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"></path>
          </svg>
        </a>
        <a
          href={site.social.whatsapp}
          target="_blank"
          rel="noopener noreferrer"
          aria-label="WhatsApp"
          class="inline-flex h-12 w-12 items-center justify-center rounded-full border border-foreground/20 transition-colors duration-300 hover:border-secondary hover:bg-secondary hover:text-foreground"
        >
          <svg viewBox="0 0 24 24" aria-hidden="true" class="h-5 w-5" fill="currentColor">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"></path>
          </svg>
        </a>
      </div>
    </div>
  </div>

  <footer
    class="shell mt-24 border-t border-foreground/10 pt-8 text-center text-sm text-foreground-faint"
  >
    <p>© {year} {site.name}</p>
  </footer>
</section>

<script>
  import { gsap, ScrollTrigger } from "../lib/gsap";

  function revealContact() {
    const el = document.getElementById("contact");
    if (!el) return;
    const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    const masks = el.querySelectorAll<HTMLElement>("[data-mask] > *");
    const reveals = el.querySelectorAll<HTMLElement>("[data-reveal]");

    if (reduce) {
      gsap.set(masks, { yPercent: 0 });
      gsap.set(reveals, { autoAlpha: 1, y: 0 });
      return;
    }

    gsap.fromTo(
      masks,
      { yPercent: 110 },
      {
        yPercent: 0,
        duration: 1,
        ease: "power4.out",
        stagger: 0.1,
        scrollTrigger: { id: "reveal", trigger: el, start: "top 75%" },
      },
    );
    gsap.fromTo(
      reveals,
      { autoAlpha: 0, y: 40 },
      {
        autoAlpha: 1,
        y: 0,
        duration: 0.9,
        ease: "power3.out",
        stagger: 0.1,
        // Drop the residual inline transform so finished reveals don't keep
        // their own GPU layer (a mobile repaint/ghosting source).
        clearProps: "transform",
        scrollTrigger: { id: "reveal", trigger: el, start: "top 70%" },
      },
    );
    ScrollTrigger.refresh();
  }

  document.addEventListener("astro:page-load", revealContact);
</script>
