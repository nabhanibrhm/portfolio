---
import { site } from "../data/site";
---

<section
  id="hero"
  class="relative isolate flex min-h-[100svh] flex-col justify-center overflow-hidden pb-24 pt-[calc(var(--header-h)+1rem)]"
>
  <!-- Background: masked grid + bottom fade. Given an explicit min-height so the
       grid backdrop keeps its presence even though the content no longer forces
       a tall section. -->
  <div class="pointer-events-none absolute inset-x-0 top-0 -z-10 min-h-[60svh] h-full">
    <div class="absolute inset-0 hero-grid"></div>
    <div class="absolute inset-0 bg-gradient-to-b from-background/10 via-background/30 to-background"></div>
  </div>

  <div class="shell flex w-full flex-col items-center gap-6 text-center md:gap-8">
    <div class="hero-memoji" data-reveal>
      <img src="/neutral-memoji.webp" alt="Luthfi Nabhan Ibrahim" width="240" height="240" />
      <img src="/memoji-smile.webp" alt="" aria-hidden="true" width="240" height="240" class="memoji-smile" />
    </div>

    <p class="eyebrow" data-reveal>
      {site.role} · {site.location}
    </p>

    <p class="max-w-prose text-lg text-foreground-muted text-balance md:text-xl" data-reveal>
      {site.tagline}
    </p>

    <div data-reveal>
      <a
        href="/#work"
        data-nav
        class="inline-flex items-center gap-2 rounded-full bg-accent px-6 py-3 text-sm font-medium text-background transition-colors duration-300 ease-smooth hover:bg-accent-deep"
      >
        View work
        <span aria-hidden="true">↓</span>
      </a>
    </div>
  </div>

</section>

<style>
  .hero-memoji {
    position: relative;
    height: clamp(14rem, 34vw, 24rem);
    aspect-ratio: 1 / 1;
  }
  /* Both faces stacked & cropped identically (source has a tall transparent
     lower region) so the smile lines up over the neutral one. The bounce +
     swap loop is driven by GSAP (see the script below). */
  .hero-memoji img {
    position: absolute;
    inset: 0;
    height: 100%;
    width: 100%;
    object-fit: cover;
    object-position: center top;
    will-change: transform, opacity;
  }
  .memoji-smile {
    opacity: 0;
  }
  .hero-grid {
    background-image:
      linear-gradient(to right, rgb(var(--fg) / 0.05) 1px, transparent 1px),
      linear-gradient(to bottom, rgb(var(--fg) / 0.05) 1px, transparent 1px);
    background-size: 64px 64px;
    mask-image: radial-gradient(ellipse 80% 60% at 50% 40%, #000 30%, transparent 75%);
    -webkit-mask-image: radial-gradient(ellipse 80% 60% at 50% 40%, #000 30%, transparent 75%);
    /* Rasterize the masked grid into its own GPU layer once. Without this the
       mask is recomposited every scroll frame — the source of the hero-only
       jank. On a static layer the compositor just translates the cached texture. */
    transform: translateZ(0);
    backface-visibility: hidden;
  }
</style>

<script>
  import { gsap } from "../lib/gsap";

  function runHeroIntro() {
    const hero = document.getElementById("hero");
    if (!hero) return;
    const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    const lines = hero.querySelectorAll<HTMLElement>("[data-mask] > *");
    const fades = hero.querySelectorAll<HTMLElement>("[data-reveal]");

    if (reduce) {
      gsap.set(lines, { yPercent: 0 });
      gsap.set(fades, { autoAlpha: 1, y: 0 });
      return;
    }

    const tl = gsap.timeline();
    tl.fromTo(
      lines,
      { yPercent: 110 },
      { yPercent: 0, duration: 1, ease: "power4.out", stagger: 0.08 },
    );
    tl.fromTo(
      fades,
      { autoAlpha: 0, y: 18 },
      { autoAlpha: 1, y: 0, duration: 0.8, ease: "power3.out", stagger: 0.1 },
      "-=0.55",
    );

    runMemojiLoop();
  }

  // Looping bounce + neutral↔smile swap, driven by GSAP. Sequence reads
  // flat → squash (swap to smile) → stretch/settle → hold → squash (swap to
  // flat) → stretch/settle → hold → repeat. The image swap fires at each
  // squash low-point so the bounce hides it. Scaling only the <img>s (not the
  // wrapper) keeps it clear of the reveal's y/autoAlpha on .hero-memoji.
  let memojiTl: gsap.core.Timeline | null = null;
  function runMemojiLoop() {
    const wrap = document.querySelector<HTMLElement>("#hero .hero-memoji");
    if (!wrap) return;
    if (window.matchMedia("(prefers-reduced-motion: reduce)").matches) return;

    const faces = wrap.querySelectorAll<HTMLElement>("img");
    const neutral = wrap.querySelector<HTMLElement>("img:not(.memoji-smile)");
    const smile = wrap.querySelector<HTMLElement>(".memoji-smile");
    if (!faces.length || !neutral || !smile) return;

    memojiTl?.kill();
    memojiTl = gsap.timeline({ repeat: -1 });
    memojiTl
      // → smile (hide neutral so it can't show through the smile's transparency)
      .to(faces, { scale: 0.88, duration: 0.18, ease: "power2.in" }, "+=1.4")
      .set(smile, { opacity: 1 })
      .set(neutral, { opacity: 0 })
      .to(faces, { scale: 1.06, duration: 0.16, ease: "power2.out" })
      .to(faces, { scale: 1, duration: 0.5, ease: "elastic.out(1, 0.5)" })
      // → flat
      .to(faces, { scale: 0.88, duration: 0.18, ease: "power2.in" }, "+=1.4")
      .set(neutral, { opacity: 1 })
      .set(smile, { opacity: 0 })
      .to(faces, { scale: 1.06, duration: 0.16, ease: "power2.out" })
      .to(faces, { scale: 1, duration: 0.5, ease: "elastic.out(1, 0.5)" });
  }

  // Wait for the preloader on first load; run immediately on later navigations.
  function scheduleHeroIntro() {
    if ((window as any).__preloaded) runHeroIntro();
    else window.addEventListener("preloader:done", runHeroIntro, { once: true });
  }

  document.addEventListener("astro:page-load", scheduleHeroIntro);
</script>
