---
import { site } from "../data/site";
---

<section
  id="hero"
  class="relative isolate flex min-h-[100svh] flex-col justify-center overflow-hidden py-[calc(var(--header-h)+1.5rem)]"
>
  <!-- Parallax background (WebGL-lite: blurred gradient orbs + grid) -->
  <div class="pointer-events-none absolute inset-0 -z-10">
    <div data-orb data-parallax="0.25" class="orb orb--accent"></div>
    <div data-orb data-parallax="-0.18" class="orb orb--secondary"></div>
    <div class="absolute inset-0 hero-grid"></div>
    <div class="absolute inset-0 bg-gradient-to-b from-background/10 via-background/30 to-background"></div>
  </div>

  <div class="shell w-full">
    <p class="eyebrow mb-6 md:mb-8" data-reveal>
      {site.role} · {site.location}
    </p>

    <h1 class="hero-title font-bold tracking-tightest">
      <span class="block overflow-hidden" data-mask><span class="block">Luthfi</span></span>
      <span class="block overflow-hidden" data-mask>
        <span class="block text-accent">{site.highlight}</span>
      </span>
      <span class="block overflow-hidden" data-mask><span class="block">Ibrahim</span></span>
    </h1>

    <div class="mt-8 flex flex-col gap-8 md:mt-12 md:flex-row md:items-end md:justify-between">
      <p class="max-w-prose text-lg text-foreground-muted text-balance md:text-xl" data-reveal>
        {site.tagline}
      </p>

      <div class="flex shrink-0 flex-wrap items-center gap-3" data-reveal>
        <a
          href="/#work"
          data-nav
          class="inline-flex items-center gap-2 rounded-full bg-accent px-6 py-3 text-sm font-medium text-background transition-colors duration-300 ease-smooth hover:bg-accent-deep"
        >
          View work
          <span aria-hidden="true">→</span>
        </a>
        <a
          href="/#contact"
          data-nav
          class="inline-flex items-center gap-2 rounded-full border border-foreground/20 px-6 py-3 text-sm font-medium text-foreground transition-colors duration-300 ease-smooth hover:border-secondary hover:bg-secondary hover:text-foreground"
        >
          Get in touch
        </a>
      </div>
    </div>
  </div>

  <!-- Scroll cue -->
  <a
    href="/#about"
    data-nav
    class="group absolute bottom-8 left-1/2 flex -translate-x-1/2 flex-col items-center gap-2 text-foreground-faint transition-colors hover:text-foreground"
    data-reveal
    aria-label="Scroll to about"
  >
    <span class="font-mono text-[10px] uppercase tracking-kicker">Scroll</span>
    <span class="scroll-line"></span>
  </a>
</section>

<style>
  .hero-title {
    font-size: clamp(3rem, 13vw, 11rem);
    line-height: 0.92;
  }
  .orb {
    position: absolute;
    border-radius: 9999px;
    filter: blur(80px);
    opacity: 0.55;
    will-change: transform;
  }
  .orb--accent {
    top: -8%;
    right: -5%;
    height: 42vw;
    width: 42vw;
    max-height: 620px;
    max-width: 620px;
    background: radial-gradient(circle at center, #cb2957, transparent 68%);
  }
  .orb--secondary {
    bottom: -12%;
    left: -8%;
    height: 38vw;
    width: 38vw;
    max-height: 560px;
    max-width: 560px;
    background: radial-gradient(circle at center, #a81f45, transparent 68%);
    opacity: 0.5;
  }
  .hero-grid {
    background-image:
      linear-gradient(to right, rgba(238, 238, 238, 0.04) 1px, transparent 1px),
      linear-gradient(to bottom, rgba(238, 238, 238, 0.04) 1px, transparent 1px);
    background-size: 64px 64px;
    mask-image: radial-gradient(ellipse 80% 60% at 50% 40%, #000 30%, transparent 75%);
    -webkit-mask-image: radial-gradient(ellipse 80% 60% at 50% 40%, #000 30%, transparent 75%);
  }
  .scroll-line {
    position: relative;
    display: block;
    height: 48px;
    width: 1px;
    overflow: hidden;
    background: rgba(238, 238, 238, 0.15);
  }
  .scroll-line::after {
    content: "";
    position: absolute;
    inset: 0;
    background: #cb2957;
    animation: scroll-cue 2s ease-in-out infinite;
  }
  @keyframes scroll-cue {
    0% { transform: translateY(-100%); }
    60%, 100% { transform: translateY(100%); }
  }
  @media (prefers-reduced-motion: reduce) {
    .scroll-line::after { animation: none; }
  }
</style>

<script>
  import { gsap } from "../lib/gsap";

  function runHeroIntro() {
    const hero = document.getElementById("hero");
    if (!hero) return;
    const reduce = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
    const lines = hero.querySelectorAll<HTMLElement>("[data-mask] > *");
    const fades = hero.querySelectorAll<HTMLElement>("[data-reveal]");

    if (reduce) {
      gsap.set(lines, { yPercent: 0 });
      gsap.set(fades, { autoAlpha: 1, y: 0 });
      return;
    }

    const tl = gsap.timeline();
    tl.fromTo(
      lines,
      { yPercent: 110 },
      { yPercent: 0, duration: 1, ease: "power4.out", stagger: 0.08 },
    );
    tl.fromTo(
      fades,
      { autoAlpha: 0, y: 18 },
      { autoAlpha: 1, y: 0, duration: 0.8, ease: "power3.out", stagger: 0.1 },
      "-=0.55",
    );

    // Subtle mouse parallax on the orbs (depth without WebGL)
    const orbs = gsap.utils.toArray<HTMLElement>("[data-orb]");
    window.addEventListener(
      "pointermove",
      (e) => {
        const cx = e.clientX / window.innerWidth - 0.5;
        const cy = e.clientY / window.innerHeight - 0.5;
        orbs.forEach((o, i) => {
          const depth = (i + 1) * 24;
          gsap.to(o, { x: cx * depth, y: cy * depth, duration: 1, ease: "power3.out" });
        });
      },
      { passive: true },
    );
  }

  // Wait for the preloader on first load; run immediately on later navigations.
  function scheduleHeroIntro() {
    if ((window as any).__preloaded) runHeroIntro();
    else window.addEventListener("preloader:done", runHeroIntro, { once: true });
  }

  document.addEventListener("astro:page-load", scheduleHeroIntro);
</script>
