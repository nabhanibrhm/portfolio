---
import Layout from "../../layouts/Layout.astro";
import { projects, getProject, site } from "../../data/site";

export function getStaticPaths() {
  return projects.map((p) => ({ params: { slug: p.slug } }));
}

const { slug } = Astro.params;
const project = getProject(slug);
if (!project) return Astro.redirect("/404");

const idx = projects.findIndex((p) => p.slug === project.slug);
const next = projects[(idx + 1) % projects.length];
// Monochrome cover glow — warm-grey palette (sage / mid-grey), no crimson.
const accentHex = project.accent === "accent" ? "#c1c1a9" : "#8b8a87";
---

<Layout
  title={`${project.title} — ${site.name}`}
  description={project.description}
>
  <article class="anchor-offset pb-28 pt-32 md:pb-40 md:pt-40">
    <div class="shell">
      <a
        href="/#work"
        data-nav
        class="eyebrow inline-flex items-center gap-2 transition-colors hover:text-foreground"
      >
        ← Back to work
      </a>

      <header class="mt-10 md:mt-16">
        <p class="eyebrow mb-6" style={`color:${accentHex}`}>
          {project.category}
        </p>
        <h1
          class="max-w-4xl text-4xl font-semibold leading-[1.02] tracking-tightest md:text-7xl"
        >
          {project.title}
        </h1>
      </header>

      <!-- Cover (brand-color media stand-in) -->
      <div
        class="mt-12 overflow-hidden rounded-3xl border border-foreground/10"
        style={`aspect-ratio:16/7; background: radial-gradient(120% 120% at 100% 0%, ${accentHex}cc, transparent 55%), linear-gradient(160deg,#272727,#141413);`}
        data-parallax="-0.06"
      >
      </div>

      <div class="mt-14 grid gap-10 md:grid-cols-12">
        <div class="md:col-span-8">
          <p
            class="max-w-prose text-xl leading-relaxed text-foreground-muted md:text-2xl"
          >
            {project.description}
          </p>
        </div>
        <aside class="md:col-span-4 md:pl-6">
          <p class="eyebrow mb-4">Stack</p>
          <ul class="flex flex-wrap gap-2">
            {
              project.tags.map((t) => (
                <li class="rounded-full border border-foreground/15 px-3.5 py-1.5 font-mono text-xs text-foreground-muted">
                  {t}
                </li>
              ))
            }
          </ul>
        </aside>
      </div>
    </div>

    <!-- Next project -->
    <a
      href={`/work/${next.slug}`}
      class="group mt-24 block border-t border-foreground/10 py-12 transition-colors duration-300 hover:bg-background-soft"
    >
      <div class="shell flex items-center justify-between gap-4">
        <div>
          <p class="eyebrow mb-2">Next project</p>
          <p
            class="text-2xl font-semibold tracking-tight transition-colors duration-300 group-hover:text-accent md:text-4xl"
          >
            {next.title}
          </p>
        </div>
        <span
          class="text-2xl transition-transform duration-300 group-hover:translate-x-2"
          >→</span
        >
      </div>
    </a>
  </article>
</Layout>
